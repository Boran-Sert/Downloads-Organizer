# ============================================================
#  SmartOSOrganizer - .gitignore
# ============================================================

# ──────────────────────────────────────────────────────────────
# Python Bytecode & Cache
# ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# ──────────────────────────────────────────────────────────────
# Distribution / Packaging
# ──────────────────────────────────────────────────────────────
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# ──────────────────────────────────────────────────────────────
# Test / Coverage Reports
# ──────────────────────────────────────────────────────────────
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.status
.pytest_cache/
.mypy_cache/
.hypothesis/
.run/

# ──────────────────────────────────────────────────────────────
# Virtual Environments
# ──────────────────────────────────────────────────────────────
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ──────────────────────────────────────────────────────────────
# IDE / Editor Settings
# ──────────────────────────────────────────────────────────────
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# PyCharm / IntelliJ
.idea/

# Spyder
.spyderproject
.spyproject

# Rope
.ropeproject

# ──────────────────────────────────────────────────────────────
# Proje Spesifik - Kişisel Veri & Modeller
# ──────────────────────────────────────────────────────────────

# Eğitilmiş ML modelleri (.pkl dosyaları kişisel veriye bağlıdır)
models/*.pkl

# Kişisel veri setleri (kullanıcının kendi dosya bilgileri)
data/*.csv

# csv.py - Lokal veri seti oluşturma scripti (geliştirme aracı)
csv.py

# ──────────────────────────────────────────────────────────────
# OS Specific
# ──────────────────────────────────────────────────────────────

# Windows
Thumbs.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~

# ──────────────────────────────────────────────────────────────
# Miscellaneous
# ──────────────────────────────────────────────────────────────
*.log
*.mo
*.pot
__pypackages__/
.pybuilder/
target/
.ipynb_checkpoints
profile_default/
ipython_config.py
docs/_build/
/site
.dmypy.json
dmypy.json
.pyre/
.pytype/
cython_debug/
celerybeat-schedule
celerybeat.pid
*.sage.py
